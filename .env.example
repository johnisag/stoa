# Server Configuration
STOA_PORT=3011

# Database — path is relative to the directory Stoa is started from.
DB_PATH=./stoa.db

# ── Running two Stoa instances on the same machine ──
# (e.g. a dev server from your checkout + a separately-installed copy)
#
# The one that silently bites: both default to the same Tier-2 terminal-daemon
# pipe, so they'd share one daemon — a stop/restart on one kills the other's
# live terminals. Give each a UNIQUE name (uncomment + change on one of them):
# STOA_PTY_HOST_NAME=stoa-dev
#
# The other two are softer: pick a distinct STOA_PORT per instance (a taken port
# fails to start — it does NOT auto-increment), and DB_PATH is already separate
# when instances run from different folders, so only override it if they share one.

# ── Rate-limit auto-resume (opt-in) ──
# When an agent hits a provider rate/usage limit, Stoa detects it and (only if
# this is set to 1) resumes the session once the reset time has passed — turning
# dead overnight hours into throughput. Detection + the "limited / resets in N"
# badge are always on; the unattended resume is what this gates. Off by default.
# STOA_AUTO_RESUME=1

# ── Auto-answer routine prompts (opt-in) ──
# When an agent stalls on a routine prompt, Stoa (only if this is 1) presses Enter
# so an overnight fleet run doesn't wait on a 2am question. SAFETY is structural:
# Enter only ever takes the HIGHLIGHTED single-shot "Yes" of a permission menu (or
# an explicit "Press Enter to…" / "[Y/n]" default) — it can't flip a No to Yes or
# grant a blanket "allow all / don't ask again". A best-effort denylist (rm -rf,
# force-push, terraform destroy, del/rd, …) is extra defense-in-depth; anything
# blanket, destructive-looking, or unrecognized is left for you (still pushed as
# "needs your input"). Detection is always on; the unattended Enter is what this
# gates. Off by default.
# STOA_AUTO_ANSWER=1

# ── Error-loop escalation (opt-in) ──
# When a session gets STUCK — its turn ends on the same error and that error sits
# there for ~90s (a narrow provider-failure envelope, not normal output) — Stoa
# (only if this is 1) sends ONE "stuck in a loop" push so you step in, instead of
# finding it dead in the morning. ESCALATE-ONLY: the terminal is never written to,
# so a false positive costs one extra notification, never a derailed agent. A
# changing error or a flip back to working resets it. Off by default.
# STOA_ERROR_LOOP=1
# STOA_ERROR_LOOP_THRESHOLD=4       # consecutive same-error ticks (2.5s each), AND…
# STOA_ERROR_LOOP_WINDOW_MS=90000   # …the same error must persist this long

# ── Self-healing watchdog (opt-in) ──
# Keeps an unattended fleet from dying silently. Two independent, default-off knobs.
#
# 1) Hung Dispatch worker. A worker that never opens a PR or exits pins its
# concurrency slot forever. Set a wall-clock ceiling (ms) past which a still-live
# worker is reaped → 'failed', freeing the slot (the pty is left alone so you can
# still inspect it). 0/unset = never reap by age (today's behavior). Set this
# ABOVE your longest expected worker runtime so a slow-but-healthy worker survives.
# STOA_DISPATCH_WORKER_MAX_AGE_MS=7200000   # e.g. 2h
#
# 2) Wedged session. A session whose spinner never settles (a hung request, a
# frozen TUI) reads as "running" forever and you never find out. With this set to
# 1, Stoa sends ONE "may be stuck" push once a session has run continuously past
# the ceiling below. ESCALATE-ONLY: the terminal is never written to, so a false
# positive costs one extra notification, never a derailed agent. Any turn boundary
# resets the streak, so a normally-iterating agent never pages. Off by default.
# STOA_AUTO_WATCHDOG=1
# STOA_WATCHDOG_STUCK_MS=1800000    # continuous "running" before paging (default 30m)
#
# The two knobs are independent and can overlap: a wedged Dispatch worker may BOTH
# get a "may be stuck" push (knob 2) and later be reaped to free its slot (knob 1).
# That's intended — one tells you, the other reclaims the slot.
