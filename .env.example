# Copy this file to .env (cp .env.example .env) and edit. .env is gitignored.
# NOTE: `#` only starts a comment at the START of a line. Inline comments are
# NOT stripped, so `STOA_PORT=3022 # dev` sets the value to "3022 # dev".

# Server Configuration
# STOA_PORT is the canonical knob the `stoa` CLI reads and forwards to the
# server; PORT is the variable the server itself reads. Set either — STOA_PORT
# takes precedence — and the CLI keeps the displayed and listening port in sync.
# A value already in your real environment overrides what's set here.
STOA_PORT=3011
PORT=3011

# Database
DB_PATH=./stoa.db
