# Copy this file to .env (cp .env.example .env) and edit. .env is gitignored.
# NOTE: `#` only starts a comment at the START of a line. Inline comments are
# NOT stripped, so `STOA_PORT=3022 # dev` sets the value to "3022 # dev".

# Server Configuration
# STOA_PORT is the canonical knob the `stoa` CLI reads and forwards to the
# server; PORT is the variable the server itself reads. Set either — STOA_PORT
# takes precedence — and the CLI keeps the displayed and listening port in sync.
# A value already in your real environment overrides what's set here.
STOA_PORT=3011
PORT=3011

# Database — defaults to ~/.stoa/stoa.db (STOA_HOME), which lives OUTSIDE the repo
# so a re-clone / reset / reinstall can't destroy your data. You normally do NOT
# need to set this. Override only to relocate the DB; a leading ~ is expanded.
# DB_PATH=~/.stoa/stoa.db

# Session backend — auto-selected (tmux on macOS/Linux, pty on Windows). Force it
# with pty|tmux, e.g. on a Mac without tmux:
# STOA_BACKEND=pty

# Auth (a single shared token gates access; the browser carries it as a cookie).
# STOA_AUTH=off            # disable auth entirely (anyone who can reach the port)
# STOA_REQUIRE_AUTH=1      # require the token even on localhost (default: trust loopback)
# STOA_TOKEN=...           # pin the token instead of the random ~/.stoa/token
# STOA_TRUST_TAILSCALE=1   # token-free over the tailnet (see the startup-banner caveat)
# STOA_ALLOWED_ORIGINS=https://stoa.example.ts.net   # extra trusted WS origins (reverse proxy)

# Web push (VAPID). By default keys are generated once and persisted to
# ~/.stoa/vapid.json — but those are LOST on a re-clone of STOA_HOME, invalidating
# existing phone subscriptions. Pin them here to make push survive a reinstall:
# STOA_VAPID_PUBLIC_KEY=...
# STOA_VAPID_PRIVATE_KEY=...
# STOA_VAPID_SUBJECT=mailto:you@example.com
