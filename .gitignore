# Dependencies
node_modules/

# Build output
dist/
.next/
out/

# Environment — ignore ALL .env variants (.env.production, .env.development, .envrc, …)
.env
.env*
.envrc
# …but keep the public, secret-free onboarding template trackable.
!.env.example

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store

# Logs
*.log
npm-debug.log*

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code local settings (machine-local; the rest of .claude/ — agent
# configs — stays tracked). Untracked, so without this it would block
# `stoa update`'s clean-tree check.
.claude/settings.local.json

# Testing
coverage/
.cache/

# Playwright — keep baselines tracked; ignore reports and result artifacts
playwright-report/
test-results/
# Playwright browser binaries (installed by `npx playwright install`)
# are stored in the system cache, not here — nothing to ignore in the repo.

# Databases (local working copies)
.mem.db
.mem.db-wal
.mem.db-shm
stoa.db
stoa.db-wal
stoa.db-shm
# legacy name (pre-Stoa rename); kept ignored so old local DBs don't get committed
agent-os.db
agent-os.db-wal
agent-os.db-shm

# TypeScript
*.tsbuildinfo

# Vercel
.vercel

# Local docs/plans (but allow docs/setup and docs/issues for public docs)
docs/*
!docs/setup/
!docs/issues/
!docs/ROADMAP.md
.mcp.json
.git-evening

# Private development notes (open source repo)
# CLAUDE.md is checked in as a thin pointer to AGENTS.md; personal notes go in
# CLAUDE.local.md (auto-loaded by Claude Code, ignored here).
CLAUDE.local.md
master.md
progress.md
.git-evening

# Next.js auto-generates this on every build; never track it (avoids a
# perpetually-dirty tree that blocks `stoa update`).
next-env.d.ts

# Local planning / analysis scratchpads — never tracked.
todays-work.md
must-have.md
small-big.md
saturday-plan.md
workflows-must-have.md
BUGS.md
.tmp-*.mjs
tmp-*.mjs

# Kimi agent swarm scratchpads (local status/bug-hunting notes)
competitor-wins-kimi.md
new-bugs-kimi.md
