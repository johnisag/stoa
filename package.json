{
  "name": "@johnisag/stoa",
  "version": "0.2.1",
  "description": "Stoa — a self-hosted cockpit for running AI coding agents in real terminals (native on Windows, macOS, Linux)",
  "author": "johnisag",
  "bin": {
    "stoa": "./scripts/stoa.js"
  },
  "files": [
    "app/",
    "components/",
    "contexts/",
    "data/",
    "hooks/",
    "lib/",
    "mcp/",
    "public/",
    "scripts/",
    "stores/",
    "styles/",
    "next.config.ts",
    "postcss.config.mjs",
    "server.ts",
    "tsconfig.json",
    "package-lock.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "setup": "node scripts/setup.js",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnisag/stoa.git"
  },
  "keywords": [
    "claude",
    "ai",
    "terminal",
    "tmux",
    "agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "bugs": {
    "url": "https://github.com/johnisag/stoa/issues"
  },
  "homepage": "https://github.com/johnisag/stoa#readme",
  "dependencies": {
